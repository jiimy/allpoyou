    "summary": "상대의 기술을 끌어모으는 특성이나 기술의 영향을 받지 않는다."
  },
  "240": {
    "nameKo": "미러아머",
    "summary": "자신이 받는 능력 다운 효과에 한해 되받아친다."
  },
  "241": {
    "nameKo": "그대로꿀꺽미사일",
    "summary": "파도타기나 다이빙을 쓰면 먹이를 물어온다. 데미지를 받으면 먹이를 토해내서 공격한다."
  },
  "242": {
    "nameKo": "굳건한신념",
    "summary": "상대의 기술을 끌어모으는 특성이나 기술의 영향을 받지 않는다."
  },
  "243": {
    "nameKo": "증기기관",
    "summary": "물타입이나 불꽃타입 기술을 받으면 스피드가 매우 크게 올라간다."
  },
  "244": {
    "nameKo": "펑크록",
    "summary": "소리 기술의 위력이 올라간다. 상대로부터 받는 소리 기술의 데미지는 절반이 된다."
  },
  "245": {
    "nameKo": "모래뿜기",
    "summary": "공격을 받으면 모래바람을 일으킨다."
  },
  "246": {
    "nameKo": "얼음인분",
    "summary": "얼음인분의 보호를 받아 특수공격으로 받는 데미지가 절반이 된다."
  },
  "247": {
    "nameKo": "숙성",
    "summary": "나무열매를 숙성시켜서 효과가 2배가 된다."
  },
  "248": {
    "nameKo": "아이스페이스",
    "summary": "물리공격을 머리의 얼음이 대신 맞아주지만 모습도 바뀐다. 얼음은 싸라기눈이 내리면 원래대로 돌아온다."
  },
  "249": {
    "nameKo": "파워스폿",
    "summary": "옆에 있기만 해도 기술의 위력이 올라간다."
  },
  "250": {
    "nameKo": "의태",
    "summary": "필드의 상태에 따라 포켓몬의 타입이 바뀐다."
  },
  "251": {
    "nameKo": "배리어프리",
    "summary": "등장했을 때 상대와 같은 편의 빛의장막, 리플렉터, 오로라베일의 효과가 사라진다."
  },
  "252": {
    "nameKo": "강철정신",
    "summary": "같은 편의 강철타입 공격의 위력이 올라간다."
  },
  "253": {
    "nameKo": "멸망의바디",
    "summary": "접촉하는 기술을 받으면 3턴 후에 양쪽 모두 기절한다. 교체되면 효과가 없어진다."
  },
  "254": {
    "nameKo": "떠도는영혼",
    "summary": "접촉하는 기술로 공격해온 포켓몬과 특성을 바꾼다."
  },
  "255": {
    "nameKo": "무아지경",
    "summary": "공격이 올라가지만 처음에 선택한 기술 외에는 쓸 수 없게 된다."
  },
  "256": {
    "nameKo": "화학변화가스",
    "summary": "화학변화가스를 가진 포켓몬이 배틀에 나와 있으면 모든 포켓몬이 가진 특성의 효과가 사라지거나 발동하지 않게 된다."
  },
  "257": {
    "nameKo": "파스텔베일",
    "summary": "자신과 같은 편이 독의 상태 이상 효과를 받지 않게 된다."
  },
  "258": {
    "nameKo": "꼬르륵스위치",
    "summary": "턴이 끝날 때마다 배부른 모양, 배고픈 모양, 배부른 모양...으로 번갈아서 모습을 바꾼다."
  },
  "259": {
    "nameKo": "퀵드로",
    "summary": "상대보다 먼저 행동할 수도 있다."
  },
  "260": {
    "nameKo": "보이지않는주먹",
    "summary": "상대에게 접촉하는 기술을 사용하면 방어의 효과를 무시하고 공격할 수 있다."
  },
  "261": {
    "nameKo": "기묘한약",
    "summary": "등장했을 때 조개껍질에서 약을 흩뿌려서 능력 변화를 원래대로 되돌린다."
  },
  "262": {
    "nameKo": "트랜지스터",
    "summary": "전기타입 기술의 위력이 올라간다."
  },
  "263": {
    "nameKo": "용의턱",
    "summary": "드래곤타입 기술의 위력이 올라간다."
  },
  "264": {
    "nameKo": "백의울음",
    "summary": "상대를 쓰러뜨리면 차가운 울음소리를 내면서 공격이 올라간다."
  },
  "265": {
    "nameKo": "흑의울음",
    "summary": "상대를 쓰러뜨리면 무서운 울음소리를 내면서 특수공격이 올라간다."
  },
  "266": {
    "nameKo": "혼연일체",
    "summary": "버드렉스의 긴장감과 블리자포스의 백의울음 두 가지 특성을 겸비한다."
  },
  "267": {
    "nameKo": "혼연일체",
    "summary": "버드렉스의 긴장감과 레이스포스의 흑의울음 두 가지 특성을 겸비한다."
  },
  "268": {
    "nameKo": "가시지않는향기",
    "summary": "이 특성을 가진 포켓몬을 접촉하는 기술로 공격한 상대 포켓몬은 특성이 가시지않는향기로 바뀐다."
  },
  "269": {
    "nameKo": "넘치는씨",
    "summary": "공격을 받으면 필드를 그래스필드로 만든다."
  },
  "270": {
    "nameKo": "열교환",
    "summary": "불꽃 타입의 기술에 당하면 공격이 1랭크 올라간다. 단, 대미지는 입는다. 화상 상태에 걸리지 않는다."
  },
  "271": {
    "nameKo": "분노의껍질",
    "summary": "HP가 절반일 때 방어와 특수방어가 1랭크 떨어지고 공격과 특수공격, 스피드가 1랭크 올라간다."
  },
  "272": {
    "nameKo": "정화의소금",
    "summary": "상태 이상에 걸리지 않으며 고스트 타입 기술의 데미지를 절반만 받는다."
  },
  "273": {
    "nameKo": "노릇노릇바디",
    "summary": "불꽃 타입 기술의 데미지를 입지 않는다. 방어가 2랭크 상승한다."
  },
  "274": {
    "nameKo": "바람타기",
    "summary": "풍이나 바람과 관련된 기술에 맞아도 데미지를 입지 않고 공격 1랭크가 올라간다."
  },
  "275": {
    "nameKo": "파수견",
    "summary": "위협을 받으면 공격이 올라간다. 포켓몬을 교체시키는 기술이나 도구의 효과를 받지 않는다."
  },
  "276": {
    "nameKo": "바위나르기",
    "summary": "바위 타입 기술의 위력을 50% 올려준다."
  },
  "277": {
    "nameKo": "풍력발전",
    "summary": "바람과 관련된 기술을 맞으면 '충전' 상태가 되어 다음 전기 타입 기술의 위력이 2배가 된다."
  },
  "278": {
    "nameKo": "Zero to Hero",
    "summary": "The Pokémon transforms into its Hero Form when it switches out."
  },
  "279": {
    "nameKo": "사령탑",
    "summary": "배틀에 나갈 때 아군 싸리용이 어써러샤의 입으로 들어가 지시를 내린다."
  },
  "280": {
    "nameKo": "전기로바꾸기",
    "summary": "공격을 받으면 '충전' 상태가 되어 다음 전기 타입 기술의 위력이 2배가 된다."
  },
  "281": {
    "nameKo": "고대활성",
    "summary": "쾌청 날씨이거나 '부스터에너지'를 지니고 있을 때, 자신의 가장 높은 능력치가 상승한다."
  },
  "282": {
    "nameKo": "쿼크차지",
    "summary": "일렉트릭필드이거나 '부스터에너지'를 지니고 있을 때, 자신의 가장 높은 능력치가 상승한다."
  },
  "283": {
    "nameKo": "황금몸",
    "summary": "상대방이 쓰는 모든 변화기를 완전히 무시한다."
  },
  "284": {
    "nameKo": "재앙의그릇",
    "summary": "자신을 제외한 모든 포켓몬의 특수공격을 떨어뜨린다."
  },
  "285": {
    "nameKo": "재앙의검",
    "summary": "자신을 제외한 모든 포켓몬의 방어를 떨어뜨린다."
  },
  "286": {
    "nameKo": "재앙의목간",
    "summary": "자신을 제외한 모든 포켓몬의 공격을 떨어뜨린다."
  },
  "287": {
    "nameKo": "재앙의구슬",
    "summary": "자신을 제외한 모든 포켓몬의 특수방어를 떨어뜨린다."
  },
  "288": {
    "nameKo": "진홍빛고동",
    "summary": "배틀에 나올 때 날씨를 쾌청으로 만든다. 쾌청 상태에서는 자신의 공격이 상승한다."
  },
  "289": {
    "nameKo": "하드론엔진",
    "summary": "배틀에 나올 때 필드를 '일렉트릭필드'로 만든다. 일렉트릭필드 위에서는 자신의 특수공격이 상승한다."
  },
  "290": {
    "nameKo": "편승",
    "summary": "상대 포켓몬의 능력치가 올라가면 본인도 똑같이 그 능력치를 올린다."
  },
  "291": {
    "nameKo": "되새김길",
    "summary": "나무열매를 먹으면, 다음 턴 종료 시에 그 나무열매를 한 번 더 먹는다."
  },
  "292": {
    "nameKo": "예리함",
    "summary": "베기 속성의 기술의 위력이 1.5배 상승한다."
  },
  "293": {
    "nameKo": "총대장",
    "summary": "배틀에 나올 때 이미 쓰러진 아군 포켓몬의 수만큼 자신의 공격과 특수공격이 상승한다."
  },
  "294": {
    "nameKo": "협연",
    "summary": "배틀에 나올 때 아군의 능력치 변화를 그대로 복사한다."
  },
  "295": {
    "nameKo": "독치장",
    "summary": "물리 공격을 받으면 상대 필드에 '독압정'을 뿌린다."
  },
  "296": {
    "nameKo": "테일아머",
    "summary": "상대 포켓몬은 선공기를 쓸 수 없다."
  },
  "297": {
    "nameKo": "흙먹기",
    "summary": "땅 타입 기술을 맞으면 데미지를 입지 않고 체력을 회복한다."
  },
  "298": {
    "nameKo": "균사의힘",
    "summary": "변화기를 쓸 때 무조건 후공하게 되지만, 상대의 특성을 무시하고 변화기를 적중시킨다."
  },
  "299": {
    "nameKo": "심안",
    "summary": "노말타입과 격투타입 기술을 고스트타입에게 맞힐 수 있다. 상대의 회피율 변화를 무시하고 명중률도 떨어지지 않는다."
  },
  "300": {
    "nameKo": "감미로운꿀",
    "summary": "등장 시 상대의 회피율을 1단계 떨어트린다."
  },
  "301": {
    "nameKo": "대접",
    "summary": "필드에 등장하면 같은 편의 HP를 조금 회복시킨다."
  },
  "302": {
    "nameKo": "독사슬",
    "summary": "공격이 명중하면 상대를 30%의 확률로 맹독 상태로 만든다. "
  },
  "303": {
    "nameKo": "초상투영",
    "summary": "오거폰이 테라스탈시 이 특성으로 변한다. 자신의 능력 중 하나가 1랭크 오르며 쓰고 있는 가면에 따라 오르는 능력이 다르다. 벽록의 가면-스피드, 우물의 가면-특수방어, 화덕의 가면-공격, 주춧돌의 가면-방어"
  },
  "304": {
    "nameKo": "테라체인지",
    "summary": "테라파고스가 포켓몬 배틀을 하면 테라스탈폼으로 폼체인지한다. 트레이스, 화학의힘, 리시버의 효과를 받지 않는다."
  },
  "305": {
    "nameKo": "테라셸",
    "summary": " HP가 100%일 경우 상대방이 사용하는 기술의 데미지가 반감된다."
  },
  "306": {
    "nameKo": "제로포밍",
    "summary": "날씨와 필드를 모두 없앤다."
  },
  "307": {
    "nameKo": "독조종",
    "summary": "공격에 상대방이 독, 맹독 상태가 되면 혼란 상태로 만든다."
  },
  "308": {
    "nameKo": "관통드릴",
    "summary": ": 방어를 무시하고 타격하는 대신, 공격의 피해량은 원래 데미지의 1/4로 감소하여 적용한다."
  },
  "309": {
    "nameKo": "드래곤스킨",
    "summary": "노말 타입 기술이 드래곤 타입이 되고 위력이 1.2배 상승한다. "
  },
  "310": {
    "nameKo": "Mega Sol",
    "summary": "Even when the sunlight has not turned harsh, the Pokémon can use its moves as if the weather were harsh sunlight."
  },
  "311": {
    "nameKo": "Spicy Spray",
    "summary": "When the Pokémon takes damage from a move, it burns the attacker."
  },
